#!/bin/bash
# clipedit - Clipboard Editor unificado para Linux
# https://github.com/estudiochapunov/clipedit
#
# Uso: clipedit [BANDERAS]
#
# Banderas:
#   -f, --from FORMATO   Formato de entrada (auto, html, rtf, md, text, image)
#   -t, --to FORMATO     Formato de salida (markdown, html, text, pdf)
#   -e, --editor EDITOR  Editor a usar (default: sistema)
#   -o, --output ARCHIVO Archivo de salida (default: portapapeles/clipboard)
#   -s, --source         Incluir URL de origen (solo si existe)
#   --input-selection SEL Leer desde seleccion X11 (clipboard, primary)
#   --output-selection SEL Escribir a seleccion X11 (clipboard, primary, both)
#   --targets            Listar formatos disponibles en el portapapeles
#   --peek               Mostrar diagnostico breve del portapapeles
#   --target TARGET      Extraer un target X11 especifico
#   --plain              Convertir a texto plano y copiar al portapapeles
#   --copy-only          Convertir y copiar sin abrir editor
#   --no-edit            Alias de --copy-only
#   --save-temp          No borrar archivos temporales
#   --no-emoji           Mostrar salida sobria, sin emojis
#   --strip-line-numbers Eliminar numeracion de lineas copiada desde chats/IA
#   --join-lines SPEC    Unir rangos de lineas (all, u3,7;9,14 o 3,7;9,14)
#   --stdout             Imprimir resultado final sin tocar portapapeles/editor
#   --trim               Quitar bordes vacios y espacios finales
#   --dedent             Quitar indentacion comun
#   --strip-code-fence   Quitar fences Markdown de codigo
#   --strip-prompts      Quitar prompts de terminal copiados
#   --strip-wa-msgs      Quitar encabezados de mensajes copiados/exportados de WhatsApp
#   --wa-keep CAMPOS     Preservar metadata de WhatsApp: name,date,time,datetime,all
#   --wa-place LUGAR     Ubicar metadata preservada: prefix o suffix
#   --squeeze-blank-lines Colapsar lineas vacias repetidas
#   --slug               Convertir texto a slug
#   --filename-safe      Convertir texto a nombre de archivo seguro
#   --wrap-code-fence LANG Envolver en fence Markdown
#   --dry-run            Mostrar plan y resultado sin tocar portapapeles/editor
#   --grep PATTERN       Conservar solo lineas que matchean regex
#   --grep-v PATTERN     Eliminar lineas que matchean regex
#   --version            Mostrar version
#   -h, --help           Mostrar ayuda
#
# Formatos soportados por pandoc: markdown, html, rtf, text, docx, odt, pdf, etc.

set -e

VERSION="1.6.0"
declare -a FILTER_PLAN=()

filter_strip_line_numbers=false
filter_join_lines_spec=""
filter_trim=false
filter_dedent=false
filter_strip_code_fence=false
filter_strip_prompts=false
filter_strip_wa_msgs=false
filter_wa_keep=""
filter_wa_place="prefix"
filter_squeeze_blank_lines=false
filter_make_slug=false
filter_make_filename=false
filter_wrap_code_fence_lang=""
filter_grep_pattern=""
filter_grep_v_pattern=""

reset_filter_options() {
    FILTER_PLAN=()
    filter_strip_line_numbers=false
    filter_join_lines_spec=""
    filter_trim=false
    filter_dedent=false
    filter_strip_code_fence=false
    filter_strip_prompts=false
    filter_strip_wa_msgs=false
    filter_wa_keep=""
    filter_wa_place="prefix"
    filter_squeeze_blank_lines=false
    filter_make_slug=false
    filter_make_filename=false
    filter_wrap_code_fence_lang=""
    filter_grep_pattern=""
    filter_grep_v_pattern=""
    return 0
}

require_flag_value() {
    local flag="$1"
    local argc="$2"

    if (( argc < 2 )); then
        echo "Error: $flag requiere un valor" >&2
        return 1
    fi
}

# Función auxiliar: detectar editor default del sistema
get_default_editor() {
    if [[ -n "$EDITOR" ]]; then
        echo "$EDITOR"
        return 0
    fi
    local xed_default
    xed_default=$(xdg-mime query default text/plain 2>/dev/null)
    if [[ -n "$xed_default" ]]; then
        echo "${xed_default%.desktop}"
        return 0
    fi
    echo "xdg-open"
    return 0
}

open_editor_for_clipboard_review() {
    local editor="$1"
    local file="$2"
    local icon_edit="$3"
    local before
    local after

    before=$(cksum "$file" 2>/dev/null || true)

    echo "${icon_edit}Abriendo en $editor..."
    echo "Archivo temporal: $file"
    echo ""
    echo "Para aplicar cambios a la seleccion X11 de salida:"
    echo "  1. Edita el contenido en el editor."
    echo "  2. Guarda este mismo archivo temporal."
    echo "  3. Cierra el editor."
    echo "  4. ClipEdit te preguntara si queres copiar el resultado."
    echo ""
    echo "Nota: Guardar como en otra ruta no cambia el archivo temporal que ClipEdit copiara."
    echo ""

    "$editor" "$file"

    after=$(cksum "$file" 2>/dev/null || true)
    if [[ "$before" != "$after" ]]; then
        echo "Cambios guardados detectados."
    else
        echo "No se detectaron cambios guardados en el archivo temporal."
    fi
}

selection_label() {
    case "$1" in
        clipboard) echo "CLIPBOARD" ;;
        primary) echo "PRIMARY" ;;
        both) echo "CLIPBOARD y PRIMARY" ;;
        *) echo "$1" ;;
    esac
}

read_x11_selection() {
    local selection="$1"
    local target="${2:-}"

    if [[ -n "$target" ]]; then
        xclip -selection "$selection" -t "$target" -o 2>/dev/null
    else
        xclip -selection "$selection" -o 2>/dev/null
    fi
}

copy_file_to_x11_selection() {
    local file="$1"
    local selection="$2"

    case "$selection" in
        clipboard)
            xclip -selection clipboard -i < "$file"
            ;;
        primary)
            xclip -selection primary -i < "$file"
            ;;
        both)
            xclip -selection clipboard -i < "$file"
            xclip -selection primary -i < "$file"
            ;;
    esac
}

# Función auxiliar: obtener source URL si el target existe
get_source_url() {
    local targets="$1"
    local input_selection="$2"

    if ! echo "$targets" | grep -qx "chromium/x-source-url"; then
        return 0
    fi

    read_x11_selection "$input_selection" "chromium/x-source-url" || true
}

# Función auxiliar: obtener formatos disponibles en portapapeles
get_targets() {
    local input_selection="$1"
    local targets

    targets=$(read_x11_selection "$input_selection" "TARGETS" 2>/dev/null || true)
    if [[ -n "$targets" ]]; then
        echo "$targets"
    else
        echo "text/plain"
    fi
}

print_targets() {
    local targets="$1"

    echo "Formatos disponibles en el portapapeles:"
    echo "$targets" | sed '/^[[:space:]]*$/d' | sed 's/^/  - /'
}

# Función auxiliar: detectar tipo de contenido
detect_content_type() {
    local targets="$1"
    
    if echo "$targets" | grep -qw "image/png"; then
        echo "image-png"
    elif echo "$targets" | grep -qw "image/jpeg"; then
        echo "image-jpeg"
    elif echo "$targets" | grep -qw "image/gif"; then
        echo "image-gif"
    elif echo "$targets" | grep -qw "text/html"; then
        echo "html"
    elif echo "$targets" | grep -qw "text/rtf"; then
        echo "rtf"
    elif echo "$targets" | grep -qw "text/markdown"; then
        echo "markdown"
    else
        echo "text"
    fi
}

# Función auxiliar: obtener extensión de imagen
get_image_ext() {
    case "$1" in
        image-png) echo "png" ;;
        image-jpeg) echo "jpg" ;;
        image-gif) echo "gif" ;;
        *) echo "png" ;;
    esac
}

get_clipboard_content() {
    local from="$1"
    local input_selection="$2"

    case "$from" in
        html)
            read_x11_selection "$input_selection" "text/html" || true
            ;;
        rtf)
            read_x11_selection "$input_selection" "text/rtf" || true
            ;;
        markdown)
            read_x11_selection "$input_selection" "text/markdown" || true
            ;;
        *)
            read_x11_selection "$input_selection" || true
            ;;
    esac
}

peek_clipboard() {
    local targets="$1"
    local from="$2"
    local input_selection="$3"
    local source_url

    source_url=$(get_source_url "$targets" "$input_selection")

    echo "ClipEdit peek"
    echo "Seleccion X11 de entrada: $(selection_label "$input_selection")"
    echo "Tipo detectado: $from"
    if [[ -n "$source_url" ]]; then
        echo "Source URL: $source_url"
    else
        echo "Source URL: no disponible"
    fi
    echo ""
    print_targets "$targets"

    if [[ "$from" == image-png || "$from" == image-jpeg || "$from" == image-gif ]]; then
        local img_ext
        local img_target
        local byte_count

        img_ext=$(get_image_ext "$from")
        case "$from" in
            image-jpeg) img_target="image/jpeg" ;;
            *) img_target="image/$img_ext" ;;
        esac

        byte_count=$(read_x11_selection "$input_selection" "$img_target" | wc -c | tr -d ' ')
        echo ""
        echo "Imagen: $img_target"
        echo "Tamano aproximado: ${byte_count:-0} bytes"
        return 0
    fi

    local content
    content=$(get_clipboard_content "$from" "$input_selection")
    local line_count
    if [[ -n "$content" ]]; then
        line_count=$(printf '%s\n' "$content" | wc -l | tr -d ' ')
    else
        line_count=0
    fi

    echo ""
    echo "Tamano aproximado: $(printf '%s' "$content" | wc -c | tr -d ' ') bytes"
    echo "Lineas: $line_count"
    echo ""
    echo "Preview:"
    printf '%s\n' "$content" | sed -n '1,12p'
}

strip_line_numbers_filter() {
    sed -E 's/^[[:space:]]*[0-9]+([[:space:]]*[:|.)])?[[:space:]]*([+>-][[:space:]])?//'
}

join_lines_filter() {
    local spec="$1"

    awk -v spec="$spec" '
        BEGIN {
            join_all = (spec == "" || spec == "all" || spec == "u")
            if (!join_all) {
                gsub(/^u/, "", spec)
                n = split(spec, parts, ";")
                for (i = 1; i <= n; i++) {
                    if (parts[i] ~ /^[0-9]+,[0-9]+$/) {
                        split(parts[i], range, ",")
                        start = range[1] + 0
                        end = range[2] + 0
                        if (start > end) {
                            tmp = start
                            start = end
                            end = tmp
                        }
                        for (line = start; line <= end; line++) {
                            join[line] = parts[i]
                        }
                        starts[start] = parts[i]
                        ends[end] = parts[i]
                    }
                }
            }
        }
        function trim(s) {
            sub(/^[[:space:]]+/, "", s)
            sub(/[[:space:]]+$/, "", s)
            return s
        }
        function emit_joined() {
            if (buffer != "") {
                print buffer
                buffer = ""
            }
        }
        {
            if (join_all) {
                piece = trim($0)
                if (piece == "") next
                buffer = buffer ? buffer " " piece : piece
                next
            }

            if (starts[NR] != "") {
                emit_joined()
            }

            if (join[NR] != "") {
                piece = trim($0)
                if (piece != "") {
                    buffer = buffer ? buffer " " piece : piece
                }
                if (ends[NR] != "") {
                    emit_joined()
                }
                next
            }

            emit_joined()
            print
        }
        END {
            emit_joined()
        }
    '
}

trim_filter() {
    sed -E 's/[[:space:]]+$//' | awk '
        NF { seen = 1 }
        seen { lines[++n] = $0 }
        END {
            while (n > 0 && lines[n] ~ /^[[:space:]]*$/) n--
            for (i = 1; i <= n; i++) print lines[i]
        }
    '
}

dedent_filter() {
    awk '
        function leading_spaces(s,    match_text) {
            match(s, /^[ \t]*/)
            match_text = substr(s, RSTART, RLENGTH)
            return length(match_text)
        }
        /^[ \t]*$/ {
            lines[++n] = $0
            next
        }
        {
            indent = leading_spaces($0)
            if (!have_min || indent < min_indent) {
                min_indent = indent
                have_min = 1
            }
            lines[++n] = $0
        }
        END {
            for (i = 1; i <= n; i++) {
                if (lines[i] ~ /^[ \t]*$/) {
                    print ""
                } else {
                    print substr(lines[i], min_indent + 1)
                }
            }
        }
    '
}

strip_code_fence_filter() {
    awk '
        $0 ~ /^[[:space:]]*```/ { next }
        { print }
    '
}

strip_prompts_filter() {
    sed -E \
        -e 's/^[^[:space:]$#>]+@[^[:space:]]+:[^$#]*[$#][[:space:]]*//' \
        -e 's/^[[:space:]]*[$#][[:space:]]+//' \
        -e 's/^[[:space:]]*>[[:space:]]+//'
}

strip_wa_msgs_filter() {
    local keep="${1:-}"
    local place="${2:-prefix}"

    WA_KEEP="$keep" WA_PLACE="$place" perl -Mstrict -Mwarnings -CS -pe '
        BEGIN {
            my $raw_keep = $ENV{WA_KEEP} // "";
            our @fields;
            for my $field (split /,/, $raw_keep) {
                $field =~ s/^\s+|\s+$//g;
                next if $field eq "";
                if ($field eq "all") {
                    push @fields, qw(name date time);
                } elsif ($field eq "datetime") {
                    push @fields, qw(date time);
                } elsif ($field =~ /^(name|date|time)$/) {
                    push @fields, $field;
                }
            }
            my %seen;
            @fields = grep { !$seen{$_}++ } @fields;
        }

        sub clean_field {
            my ($value) = @_;
            $value //= "";
            $value =~ s/[\x{200e}\x{200f}\x{202a}-\x{202e}]//g;
            $value =~ s/^\s+|\s+$//g;
            return $value;
        }

        sub render_message {
            my ($name, $date, $time, $message) = @_;
            our @fields;
            return $message unless @fields;

            my %value = (
                name => clean_field($name),
                date => clean_field($date),
                time => clean_field($time),
            );
            my @parts = grep { $_ ne "" } map { $value{$_} } @fields;
            return $message unless @parts;

            my $tag = "[" . join(" ", @parts) . "]";
            if (($ENV{WA_PLACE} // "prefix") eq "suffix") {
                return "$message $tag";
            }
            return "$tag $message";
        }

        my $date = qr/\d{1,2}[.\/-]\d{1,2}[.\/-]\d{2,4}/;
        my $time = qr/\d{1,2}:\d{2}(?::\d{2})?(?:\s?[AP]M)?/i;
        chomp;

        if (/^\[([^\]]*?)\s*($date)[,\s]+($time)[^\]]*\]:\s*(.*)$/i) {
            $_ = render_message($1, $2, $3, $4) . "\n";
        } elsif (/^\[($date),?\s+($time)[^\]]*\]\s+([^:]+):\s*(.*)$/i) {
            $_ = render_message($3, $1, $2, $4) . "\n";
        } elsif (/^($date),?\s+($time)\s+-\s+([^:]+):\s*(.*)$/i) {
            $_ = render_message($3, $1, $2, $4) . "\n";
        } else {
            $_ .= "\n";
        }
    '
}

squeeze_blank_lines_filter() {
    awk '
        /^[[:space:]]*$/ {
            if (!blank) print ""
            blank = 1
            next
        }
        {
            blank = 0
            print
        }
    '
}

grep_filter() {
    local pattern="$1"

    grep -E -- "$pattern" || true
}

grep_v_filter() {
    local pattern="$1"

    grep -Ev -- "$pattern" || true
}

slug_filter() {
    local text
    text=$(cat)
    if command -v iconv >/dev/null 2>&1; then
        text=$(printf '%s' "$text" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null || printf '%s' "$text")
    fi
    printf '%s' "$text" |
        tr '[:upper:]' '[:lower:]' |
        tr '\n' ' ' |
        sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

filename_safe_filter() {
    local text
    text=$(cat)
    if command -v iconv >/dev/null 2>&1; then
        text=$(printf '%s' "$text" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null || printf '%s' "$text")
    fi
    printf '%s' "$text" |
        tr '\n' ' ' |
        sed -E 's/[\/:*?"<>|]+/-/g; s/[[:space:]]+/_/g; s/[^A-Za-z0-9._-]+/-/g; s/[-_]{2,}/_/g; s/[-_]+\././g; s/^[-_.]+//; s/[-_.]+$//'
}

wrap_code_fence_filter() {
    local lang="$1"

    printf '```%s\n' "$lang"
    cat
    printf '\n```\n'
}

normalize_join_lines_spec() {
    local join_spec="$1"

    if [[ "$join_spec" == "u" ]]; then
        printf 'all'
    elif [[ "$join_spec" == u* ]]; then
        printf '%s' "${join_spec#u}"
    else
        printf '%s' "$join_spec"
    fi
}

validate_join_lines_spec() {
    local join_spec="$1"

    [[ -z "$join_spec" ]] && return 0
    [[ "$join_spec" == "all" ]] && return 0
    [[ "$join_spec" =~ ^[0-9]+,[0-9]+(\;[0-9]+,[0-9]+)*$ ]] && return 0
    return 1
}

validate_args() {
    local input_selection="$1"
    local output_selection="$2"
    local wa_keep="$3"
    local wa_place="$4"
    local join_lines_spec="$5"
    local wrap_code_fence_lang="$6"
    local grep_pattern="$7"
    local grep_v_pattern="$8"
    local raw_target="$9"

    if [[ "$input_selection" != "clipboard" && "$input_selection" != "primary" ]]; then
        echo "Error: --input-selection acepta solo clipboard o primary" >&2
        return 1
    fi

    if [[ "$output_selection" != "clipboard" && "$output_selection" != "primary" && "$output_selection" != "both" ]]; then
        echo "Error: --output-selection acepta solo clipboard, primary o both" >&2
        return 1
    fi

    if [[ "$wa_place" != "prefix" && "$wa_place" != "suffix" ]]; then
        echo "Error: --wa-place acepta solo prefix o suffix" >&2
        return 1
    fi

    if [[ "$wa_keep" == "__MISSING__" ]]; then
        echo "Error: --wa-keep requiere una lista de campos" >&2
        return 1
    fi

    if [[ "$wa_place" == "__MISSING__" ]]; then
        echo "Error: --wa-place requiere prefix o suffix" >&2
        return 1
    fi

    if [[ -n "$wa_keep" && ! "$wa_keep" =~ ^(name|date|time|datetime|all)(,(name|date|time|datetime|all))*$ ]]; then
        echo "Error: --wa-keep acepta name,date,time,datetime,all o listas separadas por coma" >&2
        return 1
    fi

    if [[ "$join_lines_spec" == "__MISSING__" ]]; then
        echo "Error: --join-lines requiere una especificacion" >&2
        return 1
    fi

    if ! validate_join_lines_spec "$join_lines_spec"; then
        echo "Error: --join-lines acepta all, u3,7;9,14 o 3,7;9,14" >&2
        return 1
    fi

    if [[ "$filter_wrap_code_fence_lang" == "__MISSING__" || "$wrap_code_fence_lang" == "__MISSING__" ]]; then
        echo "Error: --wrap-code-fence requiere un lenguaje" >&2
        return 1
    fi

    if [[ "$grep_pattern" == "__MISSING__" ]]; then
        echo "Error: --grep requiere un patron" >&2
        return 1
    fi

    if [[ "$grep_v_pattern" == "__MISSING__" ]]; then
        echo "Error: --grep-v requiere un patron" >&2
        return 1
    fi

    if [[ "$raw_target" == "__MISSING__" ]]; then
        echo "Error: --target requiere un target X11" >&2
        return 1
    fi

    return 0
}

build_filter_plan() {
    FILTER_PLAN=()

    [[ "$filter_strip_line_numbers" == "true" ]] && FILTER_PLAN+=("strip-line-numbers")
    [[ "$filter_strip_prompts" == "true" ]] && FILTER_PLAN+=("strip-prompts")
    if [[ "$filter_strip_wa_msgs" == "true" ]]; then
        FILTER_PLAN+=("strip-wa-msgs:${filter_wa_keep}:${filter_wa_place}")
    fi
    [[ "$filter_strip_code_fence" == "true" ]] && FILTER_PLAN+=("strip-code-fence")
    [[ "$filter_dedent" == "true" ]] && FILTER_PLAN+=("dedent")
    [[ -n "$filter_grep_pattern" ]] && FILTER_PLAN+=("grep:${filter_grep_pattern}")
    [[ -n "$filter_grep_v_pattern" ]] && FILTER_PLAN+=("grep-v:${filter_grep_v_pattern}")
    [[ -n "$filter_join_lines_spec" ]] && FILTER_PLAN+=("join-lines:${filter_join_lines_spec}")
    [[ "$filter_squeeze_blank_lines" == "true" ]] && FILTER_PLAN+=("squeeze-blank-lines")
    [[ "$filter_trim" == "true" ]] && FILTER_PLAN+=("trim")
    [[ "$filter_make_slug" == "true" ]] && FILTER_PLAN+=("slug")
    [[ "$filter_make_filename" == "true" ]] && FILTER_PLAN+=("filename-safe")
    [[ -n "$filter_wrap_code_fence_lang" ]] && FILTER_PLAN+=("wrap-code-fence:${filter_wrap_code_fence_lang}")
    return 0
}

print_filter_plan() {
    if [[ ${#FILTER_PLAN[@]} -eq 0 ]]; then
        echo "  - (none)"
        return 0
    fi

    local step
    for step in "${FILTER_PLAN[@]}"; do
        echo "  - $step"
    done
}

apply_filter_step() {
    local content="$1"
    local step="$2"
    local op="${step%%:*}"
    local rest=""

    if [[ "$step" == *:* ]]; then
        rest="${step#*:}"
    fi

    case "$op" in
        strip-line-numbers)
            printf '%s\n' "$content" | strip_line_numbers_filter
            ;;
        strip-prompts)
            printf '%s\n' "$content" | strip_prompts_filter
            ;;
        strip-wa-msgs)
            local wa_keep="${rest%%:*}"
            local wa_place="${rest#*:}"
            if [[ "$rest" == "$wa_keep" ]]; then
                wa_place="prefix"
            fi
            printf '%s\n' "$content" | strip_wa_msgs_filter "$wa_keep" "$wa_place"
            ;;
        strip-code-fence)
            printf '%s\n' "$content" | strip_code_fence_filter
            ;;
        dedent)
            printf '%s\n' "$content" | dedent_filter
            ;;
        grep)
            printf '%s\n' "$content" | grep_filter "$rest"
            ;;
        grep-v)
            printf '%s\n' "$content" | grep_v_filter "$rest"
            ;;
        join-lines)
            printf '%s\n' "$content" | join_lines_filter "$rest"
            ;;
        squeeze-blank-lines)
            printf '%s\n' "$content" | squeeze_blank_lines_filter
            ;;
        trim)
            printf '%s\n' "$content" | trim_filter
            ;;
        slug)
            printf '%s\n' "$content" | slug_filter
            ;;
        filename-safe)
            printf '%s\n' "$content" | filename_safe_filter
            ;;
        wrap-code-fence)
            printf '%s' "$content" | wrap_code_fence_filter "$rest"
            ;;
        *)
            printf '%s' "$content"
            ;;
    esac
}

apply_filter_plan() {
    local content="$1"
    local step

    for step in "${FILTER_PLAN[@]}"; do
        content=$(apply_filter_step "$content" "$step")
    done

    printf '%s' "$content"
}

apply_text_filters() {
    local content="$1"

    build_filter_plan
    apply_filter_plan "$content"
}

# Función principal
main() {
    local opt_from="auto"
    local opt_to="edit"
    local opt_editor=""
    local opt_output_file=""
    local opt_include_source=false
    local opt_input_selection="clipboard"
    local opt_output_selection="clipboard"
    local opt_show_targets=false
    local opt_peek=false
    local opt_raw_target=""
    local opt_copy_only=false
    local opt_save_temp=false
    local opt_no_emoji=false
    local opt_stdout=false
    local opt_dry_run=false
    local opt_show_version=false
    local temp_file

    reset_filter_options
    
    # Parsear argumentos
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--from)
                require_flag_value "$1" "$#" || return 1
                opt_from="${2-}"
                shift 2
                ;;
            -t|--to)
                require_flag_value "$1" "$#" || return 1
                opt_to="${2-}"
                shift 2
                ;;
            -e|--editor)
                require_flag_value "$1" "$#" || return 1
                opt_editor="${2-}"
                shift 2
                ;;
            -o|--output)
                require_flag_value "$1" "$#" || return 1
                opt_output_file="${2-}"
                shift 2
                ;;
            -s|--source)
                opt_include_source=true
                shift
                ;;
            --input-selection|--in-sel)
                require_flag_value "$1" "$#" || return 1
                opt_input_selection="${2-}"
                shift 2
                ;;
            --output-selection|--out-sel)
                require_flag_value "$1" "$#" || return 1
                opt_output_selection="${2-}"
                shift 2
                ;;
            --in-clip)
                opt_input_selection="clipboard"
                shift
                ;;
            --in-primary)
                opt_input_selection="primary"
                shift
                ;;
            --out-clip)
                opt_output_selection="clipboard"
                shift
                ;;
            --out-primary)
                opt_output_selection="primary"
                shift
                ;;
            --both-sel)
                opt_output_selection="both"
                shift
                ;;
            --targets)
                opt_show_targets=true
                shift
                ;;
            --peek)
                opt_peek=true
                shift
                ;;
            --target)
                require_flag_value "$1" "$#" || return 1
                opt_raw_target="${2-__MISSING__}"
                shift 2
                ;;
            --plain)
                opt_to="text"
                opt_copy_only=true
                shift
                ;;
            --copy-only|--no-edit)
                opt_copy_only=true
                shift
                ;;
            --save-temp)
                opt_save_temp=true
                shift
                ;;
            --no-emoji)
                opt_no_emoji=true
                shift
                ;;
            --strip-line-numbers)
                filter_strip_line_numbers=true
                shift
                ;;
            --join-lines)
                require_flag_value "$1" "$#" || return 1
                filter_join_lines_spec=$(normalize_join_lines_spec "${2-__MISSING__}")
                shift 2
                ;;
            --stdout)
                opt_stdout=true
                shift
                ;;
            --trim)
                filter_trim=true
                shift
                ;;
            --dedent)
                filter_dedent=true
                shift
                ;;
            --strip-code-fence)
                filter_strip_code_fence=true
                shift
                ;;
            --strip-prompts)
                filter_strip_prompts=true
                shift
                ;;
            --strip-wa-msgs)
                filter_strip_wa_msgs=true
                shift
                ;;
            --wa-keep)
                require_flag_value "$1" "$#" || return 1
                filter_strip_wa_msgs=true
                filter_wa_keep="${2-__MISSING__}"
                shift 2
                ;;
            --wa-place)
                require_flag_value "$1" "$#" || return 1
                filter_strip_wa_msgs=true
                filter_wa_place="${2-__MISSING__}"
                shift 2
                ;;
            --squeeze-blank-lines)
                filter_squeeze_blank_lines=true
                shift
                ;;
            --slug)
                filter_make_slug=true
                opt_to="text"
                opt_copy_only=true
                shift
                ;;
            --filename-safe)
                filter_make_filename=true
                opt_to="text"
                opt_copy_only=true
                shift
                ;;
            --wrap-code-fence)
                require_flag_value "$1" "$#" || return 1
                filter_wrap_code_fence_lang="${2-__MISSING__}"
                shift 2
                ;;
            --dry-run)
                opt_dry_run=true
                shift
                ;;
            --grep)
                require_flag_value "$1" "$#" || return 1
                filter_grep_pattern="${2-__MISSING__}"
                shift 2
                ;;
            --grep-v)
                require_flag_value "$1" "$#" || return 1
                filter_grep_v_pattern="${2-__MISSING__}"
                shift 2
                ;;
            --version)
                opt_show_version=true
                shift
                ;;
            -h|--help)
                echo "clipedit - Clipboard Editor unificado"
                echo ""
                echo "Uso: clipedit [BANDERAS]"
                echo ""
                echo "Banderas:"
                echo "  -f, --from FORMATO   Formato de entrada (auto, html, rtf, md, text, image)"
                echo "  -t, --to FORMATO     Formato de salida (markdown, html, text, pdf)"
                echo "  -e, --editor EDITOR  Editor a usar (default: sistema)"
                echo "  -o, --output ARCHIVO Archivo de salida"
                echo "  -s, --source         Incluir URL de origen si existe"
                echo "  --input-selection SEL Leer desde seleccion X11: clipboard o primary"
                echo "  --in-sel SEL         Alias de --input-selection"
                echo "  --output-selection SEL Escribir a seleccion X11: clipboard, primary o both"
                echo "  --out-sel SEL        Alias de --output-selection"
                echo "  --in-clip            Leer desde CLIPBOARD (default)"
                echo "  --in-primary         Leer desde PRIMARY"
                echo "  --out-clip           Escribir a CLIPBOARD (default)"
                echo "  --out-primary        Escribir a PRIMARY"
                echo "  --both-sel           Escribir a CLIPBOARD y PRIMARY"
                echo "  --targets            Listar formatos disponibles en el portapapeles"
                echo "  --peek               Mostrar diagnostico breve del portapapeles"
                echo "  --target TARGET      Extraer un target X11 especifico"
                echo "  --plain              Convertir a texto plano y copiar al portapapeles"
                echo "  --copy-only          Convertir y copiar sin abrir editor"
                echo "  --no-edit            Alias de --copy-only"
                echo "  --save-temp          No borrar archivos temporales"
                echo "  --no-emoji           Mostrar salida sobria, sin emojis"
                echo "  --strip-line-numbers Eliminar numeracion de lineas copiada desde chats/IA"
                echo "  --join-lines SPEC    Unir rangos: all, u3,7;9,14 o 3,7;9,14"
                echo "  --stdout             Imprimir resultado final sin tocar portapapeles/editor"
                echo "  --trim               Quitar bordes vacios y espacios finales"
                echo "  --dedent             Quitar indentacion comun"
                echo "  --strip-code-fence   Quitar fences Markdown de codigo"
                echo "  --strip-prompts      Quitar prompts de terminal copiados"
                echo "  --strip-wa-msgs      Quitar encabezados de mensajes copiados/exportados de WhatsApp"
                echo "  --wa-keep CAMPOS     Preservar metadata WA: name,date,time,datetime,all"
                echo "  --wa-place LUGAR     Ubicar metadata WA preservada: prefix o suffix"
                echo "  --squeeze-blank-lines Colapsar lineas vacias repetidas"
                echo "  --slug               Convertir texto a slug"
                echo "  --filename-safe      Convertir texto a nombre de archivo seguro"
                echo "  --wrap-code-fence LANG Envolver en fence Markdown"
                echo "  --dry-run            Mostrar plan y resultado sin tocar portapapeles/editor"
                echo "  --grep PATTERN       Conservar solo lineas que matchean regex"
                echo "  --grep-v PATTERN     Eliminar lineas que matchean regex"
                echo "  --version            Mostrar version"
                echo "  -h, --help           Mostrar esta ayuda"
                echo ""
                echo "Ejemplos:"
                echo "  clipedit                          # Abrir en editor (detectar formato)"
                echo "  clipedit -t markdown              # Convertir a Markdown"
                echo "  clipedit -f html -t markdown      # Forzar HTML a Markdown"
                echo "  clipedit -t html -s               # Convertir a HTML con source"
                echo "  clipedit -e vim                   # Abrir con Vim"
                echo "  clipedit -o ~/doc.md             # Guardar en archivo"
                echo "  clipedit --targets                # Ver formatos disponibles"
                echo "  clipedit --peek                   # Diagnosticar contenido actual"
                echo "  clipedit --target text/html       # Extraer HTML crudo"
                echo "  clipedit --plain                  # Texto plano directo al portapapeles"
                echo "  clipedit -e vim --both-sel        # Editar y escribir en CLIPBOARD + PRIMARY"
                echo "  clipedit --in-primary --out-clip --plain"
                echo "  clipedit --strip-line-numbers --plain"
                echo "  clipedit --join-lines u3,7;9,14 --plain"
                echo "  clipedit --strip-code-fence --dedent --stdout"
                echo "  clipedit --wrap-code-fence bash --plain"
                echo "  clipedit --grep ERROR --stdout"
                echo "  clipedit --grep-v DEBUG --dry-run"
                echo "  clipedit --strip-wa-msgs --plain"
                echo "  clipedit --strip-wa-msgs --wa-keep name,date --wa-place suffix --stdout"
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    filter_wa_keep=$(printf '%s' "$filter_wa_keep" | tr -d '[:space:]')

    validate_args \
        "$opt_input_selection" \
        "$opt_output_selection" \
        "$filter_wa_keep" \
        "$filter_wa_place" \
        "$filter_join_lines_spec" \
        "$filter_wrap_code_fence_lang" \
        "$filter_grep_pattern" \
        "$filter_grep_v_pattern" \
        "$opt_raw_target" || return 1

    if [[ "$opt_raw_target" == "__MISSING__" ]]; then
        opt_raw_target=""
    fi
    [[ "$filter_wrap_code_fence_lang" == "__MISSING__" ]] && filter_wrap_code_fence_lang=""
    [[ "$filter_grep_pattern" == "__MISSING__" ]] && filter_grep_pattern=""
    [[ "$filter_grep_v_pattern" == "__MISSING__" ]] && filter_grep_v_pattern=""

    build_filter_plan

    if [[ "$opt_show_version" == "true" ]]; then
        echo "clipedit $VERSION"
        echo "repo: https://github.com/estudiochapunov/clipedit"
        return 0
    fi

    local icon_image="📷 "
    local icon_doc="📄 "
    local icon_warn="⚠️ "
    local icon_edit="📝 "
    local icon_clip="📋 "
    local icon_ok="✅ "
    if [[ "$opt_no_emoji" == "true" ]]; then
        icon_image=""
        icon_doc=""
        icon_warn=""
        icon_edit=""
        icon_clip=""
        icon_ok=""
    fi
    
    # Obtener targets del portapapeles
    local targets
    targets=$(get_targets "$opt_input_selection")

    if [[ -n "$opt_raw_target" ]]; then
        if [[ -n "$opt_output_file" ]]; then
            read_x11_selection "$opt_input_selection" "$opt_raw_target" > "$opt_output_file"
            echo "${icon_doc}Guardado: $opt_output_file"
        else
            read_x11_selection "$opt_input_selection" "$opt_raw_target"
        fi
        return 0
    fi
    
    # Detectar tipo de contenido si from=auto
    if [[ "$opt_from" == "auto" ]]; then
        opt_from=$(detect_content_type "$targets")
    fi

    if [[ "$opt_show_targets" == "true" ]]; then
        print_targets "$targets"
        return 0
    fi

    if [[ "$opt_peek" == "true" ]]; then
        peek_clipboard "$targets" "$opt_from" "$opt_input_selection"
        return 0
    fi

    if [[ "$opt_dry_run" == "true" && "$opt_to" == "edit" ]]; then
        opt_to="text"
    fi

    if [[ "$opt_stdout" == "true" && "$opt_to" == "edit" ]]; then
        opt_to="text"
    fi

    if [[ "$opt_copy_only" == "true" && "$opt_to" == "edit" ]]; then
        opt_to="text"
    fi
    
    # Determinar archivo de salida
    if [[ -n "$opt_output_file" ]]; then
        temp_file="$opt_output_file"
    else
        case "$opt_to" in
            markdown) temp_file=$(mktemp /tmp/clip-XXXXXX.md) ;;
            html)     temp_file=$(mktemp /tmp/clip-XXXXXX.html) ;;
            text)     temp_file=$(mktemp /tmp/clip-XXXXXX.txt) ;;
            pdf)      temp_file=$(mktemp /tmp/clip-XXXXXX.html) ;;
            *)        temp_file=$(mktemp /tmp/clip-XXXXXX.txt) ;;
        esac
    fi
    
    # Procesar según tipo de contenido
    local source_url=""
    if [[ "$opt_include_source" == "true" ]]; then
        source_url=$(get_source_url "$targets" "$opt_input_selection")
    fi
    
    # Imagen: extraer y guardar
    if [[ "$opt_from" == image-png || "$opt_from" == image-jpeg || "$opt_from" == image-gif ]]; then
        local img_ext
        img_ext=$(get_image_ext "$opt_from")
        local img_file
        img_file=$(mktemp /tmp/clipimg-XXXXXX.${img_ext})
        
        # Extraer imagen
        read_x11_selection "$opt_input_selection" "image/${img_ext}" > "$img_file" 2>/dev/null || \
        read_x11_selection "$opt_input_selection" > "$img_file"
        
        echo "${icon_image}Imagen guardada: $img_file"
        
        # Crear referencia según formato de salida
        case "$opt_to" in
            markdown)
                echo "![image]($img_file)" > "$temp_file"
                ;;
            html)
                echo "<img src=\"$img_file\" alt=\"image\">" > "$temp_file"
                ;;
            *)
                echo "Imagen: $img_file" > "$temp_file"
                ;;
        esac
        
        if [[ -n "$opt_output_file" ]]; then
            echo "${icon_doc}$temp_file"
        else
            # Copiar al portapapeles
            copy_file_to_x11_selection "$temp_file" "$opt_output_selection"
            if [[ "$opt_save_temp" == "true" ]]; then
                echo "${icon_doc}Temporal: $temp_file"
            else
                rm -f "$temp_file"
            fi
        fi
        return 0
    fi
    
    # Texto/HTML/RTF: procesar con pandoc
    local content
    content=$(get_clipboard_content "$opt_from" "$opt_input_selection")
    content=$(apply_text_filters "$content")
    
    # Agregar source si corresponde
    if [[ -n "$source_url" ]]; then
        content="Source: $source_url
---
$content"
    fi
    
    # Convertir según formato de salida
    case "$opt_to" in
        markdown)
            echo "$content" | pandoc -f html -t markdown > "$temp_file" 2>/dev/null || \
            echo "$content" | pandoc -f rtf -t markdown > "$temp_file" 2>/dev/null || \
            echo "$content" > "$temp_file"
            ;;
        html)
            echo "$content" | pandoc -f markdown -t html > "$temp_file" 2>/dev/null || \
            echo "$content" > "$temp_file"
            ;;
        text)
            case "$opt_from" in
                html)
                    echo "$content" | pandoc -f html -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                rtf)
                    echo "$content" | pandoc -f rtf -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                markdown)
                    echo "$content" | pandoc -f markdown -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                *)
                    echo "$content" > "$temp_file"
                    ;;
            esac
            ;;
        pdf)
            echo "$content" | pandoc -f markdown -t html > "$temp_file"
            # Crear PDF si wkhtmltopdf está disponible
            if command -v wkhtmltopdf &>/dev/null; then
                local pdf_file="${temp_file%.html}.pdf"
                wkhtmltopdf "$temp_file" "$pdf_file" 2>/dev/null
                rm -f "$temp_file"
                temp_file="$pdf_file"
                echo "${icon_doc}PDF: $temp_file"
            else
                echo "${icon_warn}wkhtmltopdf no está instalado (sudo apt install wkhtmltopdf)"
                echo "${icon_doc}Guardado como HTML: $temp_file"
            fi
            ;;
        edit)
            # Modo editor: abrir con editor
            echo "$content" > "$temp_file"
            
            if [[ -z "$opt_editor" ]]; then
                opt_editor=$(get_default_editor)
            fi
            
            open_editor_for_clipboard_review "$opt_editor" "$temp_file" "$icon_edit"
            
            # Si es archivo temporal, preguntar si copiar de vuelta
            if [[ -z "$opt_output_file" ]]; then
                echo "${icon_clip}¿Copiar a $(selection_label "$opt_output_selection") el contenido guardado del archivo temporal? (s/n)"
                read -r resp
                if [[ "$resp" == "s" || "$resp" == "S" ]]; then
                    copy_file_to_x11_selection "$temp_file" "$opt_output_selection"
                    echo "${icon_ok}Copiado a $(selection_label "$opt_output_selection")"
                fi
                if [[ "$opt_save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file"
                else
                    rm -f "$temp_file"
                fi
            else
                echo "${icon_doc}Guardado: $temp_file"
            fi
            return 0
            ;;
    esac
    
    # Si hay output file o es modo conversión
    if [[ -n "$opt_output_file" || "$opt_to" != "edit" ]]; then
        # Siempre mostrar donde quedó el archivo temporal
        if [[ -z "$opt_output_file" && "$opt_stdout" != "true" && "$opt_dry_run" != "true" && ( "$opt_copy_only" != "true" || "$opt_save_temp" == "true" ) ]]; then
            echo "${icon_doc}Temporal: $temp_file"
        fi
        
        if [[ "$opt_dry_run" == "true" ]]; then
            echo "ClipEdit dry-run"
            echo "from=$opt_from"
            echo "to=$opt_to"
            echo "output=stdout"
            echo "input_selection=$opt_input_selection"
            echo "output_selection=$opt_output_selection"
            echo "clipboard_write=false"
            echo "editor=false"
            echo "filters:"
            print_filter_plan
            echo "---"
            cat "$temp_file"
            if [[ -z "$opt_output_file" ]]; then
                if [[ "$opt_save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file" >&2
                else
                    rm -f "$temp_file"
                fi
            fi
            return 0
        fi

        if [[ "$opt_stdout" == "true" ]]; then
            cat "$temp_file"
            if [[ -z "$opt_output_file" ]]; then
                if [[ "$opt_save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file" >&2
                else
                    rm -f "$temp_file"
                fi
            fi
            return 0
        fi

        if [[ "$opt_copy_only" == "true" ]]; then
            copy_file_to_x11_selection "$temp_file" "$opt_output_selection"
            echo "${icon_ok}Copiado a $(selection_label "$opt_output_selection")"
            if [[ -z "$opt_output_file" ]]; then
                if [[ "$opt_save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file"
                else
                    rm -f "$temp_file"
                fi
            fi
            echo "${icon_ok}Convertido a $opt_to"
            return 0
        fi

        # Abrir en editor para revisar resultado
        if [[ -z "$opt_output_file" ]]; then
            if [[ -z "$opt_editor" ]]; then
                opt_editor=$(get_default_editor)
            fi
            open_editor_for_clipboard_review "$opt_editor" "$temp_file" "$icon_edit"
            
            # Preguntar si copiar al portapapeles
            echo "${icon_clip}¿Copiar a $(selection_label "$opt_output_selection") el contenido guardado del archivo temporal? (s/n)"
            read -r resp
            if [[ "$resp" == "s" || "$resp" == "S" ]]; then
                copy_file_to_x11_selection "$temp_file" "$opt_output_selection"
                echo "${icon_ok}Copiado a $(selection_label "$opt_output_selection")"
            fi
            if [[ "$opt_save_temp" == "true" ]]; then
                echo "${icon_doc}Temporal conservado: $temp_file"
            else
                rm -f "$temp_file"
            fi
        else
            echo "${icon_doc}Guardado: $temp_file"
        fi
    fi

    echo "${icon_ok}Convertido a $opt_to"
}

main "$@"
