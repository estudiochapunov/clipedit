#!/bin/bash
# clipedit - Clipboard Editor unificado para Linux
# https://github.com/estudiochapunov/clipedit
#
# Uso: clipedit [BANDERAS]
#
# Banderas:
#   -f, --from FORMATO   Formato de entrada (auto, html, rtf, md, text, image)
#   -t, --to FORMATO     Formato de salida (markdown, html, text, pdf)
#   -e, --editor EDITOR  Editor a usar (default: sistema)
#   -o, --output ARCHIVO Archivo de salida (default: portapapeles/clipboard)
#   -s, --source         Incluir URL de origen (solo si existe)
#   --targets            Listar formatos disponibles en el portapapeles
#   --peek               Mostrar diagnostico breve del portapapeles
#   --target TARGET      Extraer un target X11 especifico
#   --plain              Convertir a texto plano y copiar al portapapeles
#   --copy-only          Convertir y copiar sin abrir editor
#   --no-edit            Alias de --copy-only
#   --save-temp          No borrar archivos temporales
#   --no-emoji           Mostrar salida sobria, sin emojis
#   --strip-line-numbers Eliminar numeracion de lineas copiada desde chats/IA
#   --join-lines SPEC    Unir rangos de lineas (all, u3,7;9,14 o 3,7;9,14)
#   --stdout             Imprimir resultado final sin tocar portapapeles/editor
#   --trim               Quitar bordes vacios y espacios finales
#   --dedent             Quitar indentacion comun
#   --strip-code-fence   Quitar fences Markdown de codigo
#   --strip-prompts      Quitar prompts de terminal copiados
#   --strip-wa-msgs      Quitar encabezados de mensajes copiados/exportados de WhatsApp
#   --wa-keep CAMPOS     Preservar metadata de WhatsApp: name,date,time,datetime,all
#   --wa-place LUGAR     Ubicar metadata preservada: prefix o suffix
#   --squeeze-blank-lines Colapsar lineas vacias repetidas
#   --slug               Convertir texto a slug
#   --filename-safe      Convertir texto a nombre de archivo seguro
#   --wrap-code-fence LANG Envolver en fence Markdown
#   --dry-run            Mostrar plan y resultado sin tocar portapapeles/editor
#   --grep PATTERN       Conservar solo lineas que matchean regex
#   --grep-v PATTERN     Eliminar lineas que matchean regex
#   --version            Mostrar version
#   -h, --help           Mostrar ayuda
#
# Formatos soportados por pandoc: markdown, html, rtf, text, docx, odt, pdf, etc.

set -e

VERSION="1.5.0"

# Función auxiliar: detectar editor default del sistema
get_default_editor() {
    if [[ -n "$EDITOR" ]]; then
        echo "$EDITOR"
        return 0
    fi
    local xed_default
    xed_default=$(xdg-mime query default text/plain 2>/dev/null)
    if [[ -n "$xed_default" ]]; then
        echo "${xed_default%.desktop}"
        return 0
    fi
    echo "xdg-open"
    return 0
}

open_editor_for_clipboard_review() {
    local editor="$1"
    local file="$2"
    local icon_edit="$3"
    local before
    local after

    before=$(cksum "$file" 2>/dev/null || true)

    echo "${icon_edit}Abriendo en $editor..."
    echo "Archivo temporal: $file"
    echo ""
    echo "Para aplicar cambios al clipboard:"
    echo "  1. Edita el contenido en el editor."
    echo "  2. Guarda este mismo archivo temporal."
    echo "  3. Cierra el editor."
    echo "  4. ClipEdit te preguntara si queres copiar el resultado al clipboard."
    echo ""
    echo "Nota: Guardar como en otra ruta no cambia el archivo temporal que ClipEdit copiara."
    echo ""

    "$editor" "$file"

    after=$(cksum "$file" 2>/dev/null || true)
    if [[ "$before" != "$after" ]]; then
        echo "Cambios guardados detectados."
    else
        echo "No se detectaron cambios guardados en el archivo temporal."
    fi
}

# Función auxiliar: obtener source URL si el target existe
get_source_url() {
    local targets="$1"

    if ! echo "$targets" | grep -qx "chromium/x-source-url"; then
        return 0
    fi

    xclip -selection clipboard -t chromium/x-source-url -o 2>/dev/null || true
}

# Función auxiliar: obtener formatos disponibles en portapapeles
get_targets() {
    xclip -selection clipboard -t TARGETS -o 2>/dev/null || echo "text/plain"
}

print_targets() {
    local targets="$1"

    echo "Formatos disponibles en el portapapeles:"
    echo "$targets" | sed '/^[[:space:]]*$/d' | sed 's/^/  - /'
}

# Función auxiliar: detectar tipo de contenido
detect_content_type() {
    local targets="$1"
    
    if echo "$targets" | grep -qw "image/png"; then
        echo "image-png"
    elif echo "$targets" | grep -qw "image/jpeg"; then
        echo "image-jpeg"
    elif echo "$targets" | grep -qw "image/gif"; then
        echo "image-gif"
    elif echo "$targets" | grep -qw "text/html"; then
        echo "html"
    elif echo "$targets" | grep -qw "text/rtf"; then
        echo "rtf"
    elif echo "$targets" | grep -qw "text/markdown"; then
        echo "markdown"
    else
        echo "text"
    fi
}

# Función auxiliar: obtener extensión de imagen
get_image_ext() {
    case "$1" in
        image-png) echo "png" ;;
        image-jpeg) echo "jpg" ;;
        image-gif) echo "gif" ;;
        *) echo "png" ;;
    esac
}

get_clipboard_content() {
    local from="$1"

    case "$from" in
        html)
            xclip -selection clipboard -t text/html -o 2>/dev/null || true
            ;;
        rtf)
            xclip -selection clipboard -t text/rtf -o 2>/dev/null || true
            ;;
        markdown)
            xclip -selection clipboard -t text/markdown -o 2>/dev/null || true
            ;;
        *)
            xclip -selection clipboard -o 2>/dev/null || true
            ;;
    esac
}

peek_clipboard() {
    local targets="$1"
    local from="$2"
    local source_url

    source_url=$(get_source_url "$targets")

    echo "ClipEdit peek"
    echo "Tipo detectado: $from"
    if [[ -n "$source_url" ]]; then
        echo "Source URL: $source_url"
    else
        echo "Source URL: no disponible"
    fi
    echo ""
    print_targets "$targets"

    if [[ "$from" == image-png || "$from" == image-jpeg || "$from" == image-gif ]]; then
        local img_ext
        local img_target
        local byte_count

        img_ext=$(get_image_ext "$from")
        case "$from" in
            image-jpeg) img_target="image/jpeg" ;;
            *) img_target="image/$img_ext" ;;
        esac

        byte_count=$(xclip -selection clipboard -t "$img_target" -o 2>/dev/null | wc -c | tr -d ' ')
        echo ""
        echo "Imagen: $img_target"
        echo "Tamano aproximado: ${byte_count:-0} bytes"
        return 0
    fi

    local content
    content=$(get_clipboard_content "$from")
    local line_count
    if [[ -n "$content" ]]; then
        line_count=$(printf '%s\n' "$content" | wc -l | tr -d ' ')
    else
        line_count=0
    fi

    echo ""
    echo "Tamano aproximado: $(printf '%s' "$content" | wc -c | tr -d ' ') bytes"
    echo "Lineas: $line_count"
    echo ""
    echo "Preview:"
    printf '%s\n' "$content" | sed -n '1,12p'
}

strip_line_numbers_filter() {
    sed -E 's/^[[:space:]]*[0-9]+([[:space:]]*[:|.)])?[[:space:]]*([+>-][[:space:]])?//'
}

join_lines_filter() {
    local spec="$1"

    awk -v spec="$spec" '
        BEGIN {
            join_all = (spec == "" || spec == "all" || spec == "u")
            if (!join_all) {
                gsub(/^u/, "", spec)
                n = split(spec, parts, ";")
                for (i = 1; i <= n; i++) {
                    if (parts[i] ~ /^[0-9]+,[0-9]+$/) {
                        split(parts[i], range, ",")
                        start = range[1] + 0
                        end = range[2] + 0
                        if (start > end) {
                            tmp = start
                            start = end
                            end = tmp
                        }
                        for (line = start; line <= end; line++) {
                            join[line] = parts[i]
                        }
                        starts[start] = parts[i]
                        ends[end] = parts[i]
                    }
                }
            }
        }
        function trim(s) {
            sub(/^[[:space:]]+/, "", s)
            sub(/[[:space:]]+$/, "", s)
            return s
        }
        function emit_joined() {
            if (buffer != "") {
                print buffer
                buffer = ""
            }
        }
        {
            if (join_all) {
                piece = trim($0)
                if (piece == "") next
                buffer = buffer ? buffer " " piece : piece
                next
            }

            if (starts[NR] != "") {
                emit_joined()
            }

            if (join[NR] != "") {
                piece = trim($0)
                if (piece != "") {
                    buffer = buffer ? buffer " " piece : piece
                }
                if (ends[NR] != "") {
                    emit_joined()
                }
                next
            }

            emit_joined()
            print
        }
        END {
            emit_joined()
        }
    '
}

trim_filter() {
    sed -E 's/[[:space:]]+$//' | awk '
        NF { seen = 1 }
        seen { lines[++n] = $0 }
        END {
            while (n > 0 && lines[n] ~ /^[[:space:]]*$/) n--
            for (i = 1; i <= n; i++) print lines[i]
        }
    '
}

dedent_filter() {
    awk '
        function leading_spaces(s,    match_text) {
            match(s, /^[ \t]*/)
            match_text = substr(s, RSTART, RLENGTH)
            return length(match_text)
        }
        /^[ \t]*$/ {
            lines[++n] = $0
            next
        }
        {
            indent = leading_spaces($0)
            if (!have_min || indent < min_indent) {
                min_indent = indent
                have_min = 1
            }
            lines[++n] = $0
        }
        END {
            for (i = 1; i <= n; i++) {
                if (lines[i] ~ /^[ \t]*$/) {
                    print ""
                } else {
                    print substr(lines[i], min_indent + 1)
                }
            }
        }
    '
}

strip_code_fence_filter() {
    awk '
        $0 ~ /^[[:space:]]*```/ { next }
        { print }
    '
}

strip_prompts_filter() {
    sed -E \
        -e 's/^[^[:space:]$#>]+@[^[:space:]]+:[^$#]*[$#][[:space:]]*//' \
        -e 's/^[[:space:]]*[$#][[:space:]]+//' \
        -e 's/^[[:space:]]*>[[:space:]]+//'
}

strip_wa_msgs_filter() {
    local keep="${1:-}"
    local place="${2:-prefix}"

    WA_KEEP="$keep" WA_PLACE="$place" perl -Mstrict -Mwarnings -CS -pe '
        BEGIN {
            my $raw_keep = $ENV{WA_KEEP} // "";
            our @fields;
            for my $field (split /,/, $raw_keep) {
                $field =~ s/^\s+|\s+$//g;
                next if $field eq "";
                if ($field eq "all") {
                    push @fields, qw(name date time);
                } elsif ($field eq "datetime") {
                    push @fields, qw(date time);
                } elsif ($field =~ /^(name|date|time)$/) {
                    push @fields, $field;
                }
            }
            my %seen;
            @fields = grep { !$seen{$_}++ } @fields;
        }

        sub clean_field {
            my ($value) = @_;
            $value //= "";
            $value =~ s/[\x{200e}\x{200f}\x{202a}-\x{202e}]//g;
            $value =~ s/^\s+|\s+$//g;
            return $value;
        }

        sub render_message {
            my ($name, $date, $time, $message) = @_;
            our @fields;
            return $message unless @fields;

            my %value = (
                name => clean_field($name),
                date => clean_field($date),
                time => clean_field($time),
            );
            my @parts = grep { $_ ne "" } map { $value{$_} } @fields;
            return $message unless @parts;

            my $tag = "[" . join(" ", @parts) . "]";
            if (($ENV{WA_PLACE} // "prefix") eq "suffix") {
                return "$message $tag";
            }
            return "$tag $message";
        }

        my $date = qr/\d{1,2}[.\/-]\d{1,2}[.\/-]\d{2,4}/;
        my $time = qr/\d{1,2}:\d{2}(?::\d{2})?(?:\s?[AP]M)?/i;
        chomp;

        if (/^\[([^\]]*?)\s*($date)[,\s]+($time)[^\]]*\]:\s*(.*)$/i) {
            $_ = render_message($1, $2, $3, $4) . "\n";
        } elsif (/^\[($date),?\s+($time)[^\]]*\]\s+([^:]+):\s*(.*)$/i) {
            $_ = render_message($3, $1, $2, $4) . "\n";
        } elsif (/^($date),?\s+($time)\s+-\s+([^:]+):\s*(.*)$/i) {
            $_ = render_message($3, $1, $2, $4) . "\n";
        } else {
            $_ .= "\n";
        }
    '
}

squeeze_blank_lines_filter() {
    awk '
        /^[[:space:]]*$/ {
            if (!blank) print ""
            blank = 1
            next
        }
        {
            blank = 0
            print
        }
    '
}

grep_filter() {
    local pattern="$1"

    grep -E -- "$pattern" || true
}

grep_v_filter() {
    local pattern="$1"

    grep -Ev -- "$pattern" || true
}

slug_filter() {
    local text
    text=$(cat)
    if command -v iconv >/dev/null 2>&1; then
        text=$(printf '%s' "$text" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null || printf '%s' "$text")
    fi
    printf '%s' "$text" |
        tr '[:upper:]' '[:lower:]' |
        tr '\n' ' ' |
        sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

filename_safe_filter() {
    local text
    text=$(cat)
    if command -v iconv >/dev/null 2>&1; then
        text=$(printf '%s' "$text" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null || printf '%s' "$text")
    fi
    printf '%s' "$text" |
        tr '\n' ' ' |
        sed -E 's/[\/:*?"<>|]+/-/g; s/[[:space:]]+/_/g; s/[^A-Za-z0-9._-]+/-/g; s/[-_]{2,}/_/g; s/[-_]+\././g; s/^[-_.]+//; s/[-_.]+$//'
}

wrap_code_fence_filter() {
    local lang="$1"

    printf '```%s\n' "$lang"
    cat
    printf '\n```\n'
}

apply_text_filters() {
    local content="$1"
    local strip_numbers="$2"
    local join_spec="$3"
    local trim_text="$4"
    local dedent_text="$5"
    local strip_fence="$6"
    local strip_prompts="$7"
    local squeeze_blanks="$8"
    local make_slug="$9"
    local make_filename="${10}"
    local wrap_lang="${11}"
    local grep_pattern="${12}"
    local grep_v_pattern="${13}"
    local strip_wa_msgs="${14}"
    local wa_keep="${15}"
    local wa_place="${16}"

    if [[ "$strip_numbers" == "true" ]]; then
        content=$(printf '%s\n' "$content" | strip_line_numbers_filter)
    fi

    if [[ "$strip_prompts" == "true" ]]; then
        content=$(printf '%s\n' "$content" | strip_prompts_filter)
    fi

    if [[ "$strip_wa_msgs" == "true" ]]; then
        content=$(printf '%s\n' "$content" | strip_wa_msgs_filter "$wa_keep" "$wa_place")
    fi

    if [[ "$strip_fence" == "true" ]]; then
        content=$(printf '%s\n' "$content" | strip_code_fence_filter)
    fi

    if [[ "$dedent_text" == "true" ]]; then
        content=$(printf '%s\n' "$content" | dedent_filter)
    fi

    if [[ -n "$grep_pattern" ]]; then
        content=$(printf '%s\n' "$content" | grep_filter "$grep_pattern")
    fi

    if [[ -n "$grep_v_pattern" ]]; then
        content=$(printf '%s\n' "$content" | grep_v_filter "$grep_v_pattern")
    fi

    if [[ -n "$join_spec" ]]; then
        content=$(printf '%s\n' "$content" | join_lines_filter "$join_spec")
    fi

    if [[ "$squeeze_blanks" == "true" ]]; then
        content=$(printf '%s\n' "$content" | squeeze_blank_lines_filter)
    fi

    if [[ "$trim_text" == "true" ]]; then
        content=$(printf '%s\n' "$content" | trim_filter)
    fi

    if [[ "$make_slug" == "true" ]]; then
        content=$(printf '%s\n' "$content" | slug_filter)
    fi

    if [[ "$make_filename" == "true" ]]; then
        content=$(printf '%s\n' "$content" | filename_safe_filter)
    fi

    if [[ -n "$wrap_lang" ]]; then
        content=$(printf '%s' "$content" | wrap_code_fence_filter "$wrap_lang")
    fi

    printf '%s' "$content"
}

# Función principal
main() {
    local from="auto"
    local to="edit"
    local editor=""
    local output_file=""
    local include_source=false
    local show_targets=false
    local peek=false
    local raw_target=""
    local copy_only=false
    local save_temp=false
    local no_emoji=false
    local strip_line_numbers=false
    local join_lines_spec=""
    local stdout_output=false
    local trim_text=false
    local dedent_text=false
    local strip_code_fence=false
    local strip_prompts=false
    local strip_wa_msgs=false
    local wa_keep=""
    local wa_place="prefix"
    local squeeze_blank_lines=false
    local make_slug=false
    local make_filename=false
    local wrap_code_fence_lang=""
    local dry_run=false
    local grep_pattern=""
    local grep_v_pattern=""
    local show_version=false
    local temp_file
    
    # Parsear argumentos
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--from)
                from="$2"
                shift 2
                ;;
            -t|--to)
                to="$2"
                shift 2
                ;;
            -e|--editor)
                editor="$2"
                shift 2
                ;;
            -o|--output)
                output_file="$2"
                shift 2
                ;;
            -s|--source)
                include_source=true
                shift
                ;;
            --targets)
                show_targets=true
                shift
                ;;
            --peek)
                peek=true
                shift
                ;;
            --target)
                raw_target="$2"
                shift 2
                ;;
            --plain)
                to="text"
                copy_only=true
                shift
                ;;
            --copy-only|--no-edit)
                copy_only=true
                shift
                ;;
            --save-temp)
                save_temp=true
                shift
                ;;
            --no-emoji)
                no_emoji=true
                shift
                ;;
            --strip-line-numbers)
                strip_line_numbers=true
                shift
                ;;
            --join-lines)
                join_lines_spec="$2"
                if [[ "$join_lines_spec" == u* && "$join_lines_spec" != "u" ]]; then
                    join_lines_spec="${join_lines_spec#u}"
                elif [[ "$join_lines_spec" == "u" ]]; then
                    join_lines_spec="all"
                fi
                shift 2
                ;;
            --stdout)
                stdout_output=true
                shift
                ;;
            --trim)
                trim_text=true
                shift
                ;;
            --dedent)
                dedent_text=true
                shift
                ;;
            --strip-code-fence)
                strip_code_fence=true
                shift
                ;;
            --strip-prompts)
                strip_prompts=true
                shift
                ;;
            --strip-wa-msgs)
                strip_wa_msgs=true
                shift
                ;;
            --wa-keep)
                strip_wa_msgs=true
                wa_keep="$2"
                shift 2
                ;;
            --wa-place)
                strip_wa_msgs=true
                wa_place="$2"
                shift 2
                ;;
            --squeeze-blank-lines)
                squeeze_blank_lines=true
                shift
                ;;
            --slug)
                make_slug=true
                to="text"
                copy_only=true
                shift
                ;;
            --filename-safe)
                make_filename=true
                to="text"
                copy_only=true
                shift
                ;;
            --wrap-code-fence)
                wrap_code_fence_lang="$2"
                shift 2
                ;;
            --dry-run)
                dry_run=true
                shift
                ;;
            --grep)
                grep_pattern="$2"
                shift 2
                ;;
            --grep-v)
                grep_v_pattern="$2"
                shift 2
                ;;
            --version)
                show_version=true
                shift
                ;;
            -h|--help)
                echo "clipedit - Clipboard Editor unificado"
                echo ""
                echo "Uso: clipedit [BANDERAS]"
                echo ""
                echo "Banderas:"
                echo "  -f, --from FORMATO   Formato de entrada (auto, html, rtf, md, text, image)"
                echo "  -t, --to FORMATO     Formato de salida (markdown, html, text, pdf)"
                echo "  -e, --editor EDITOR  Editor a usar (default: sistema)"
                echo "  -o, --output ARCHIVO Archivo de salida"
                echo "  -s, --source         Incluir URL de origen si existe"
                echo "  --targets            Listar formatos disponibles en el portapapeles"
                echo "  --peek               Mostrar diagnostico breve del portapapeles"
                echo "  --target TARGET      Extraer un target X11 especifico"
                echo "  --plain              Convertir a texto plano y copiar al portapapeles"
                echo "  --copy-only          Convertir y copiar sin abrir editor"
                echo "  --no-edit            Alias de --copy-only"
                echo "  --save-temp          No borrar archivos temporales"
                echo "  --no-emoji           Mostrar salida sobria, sin emojis"
                echo "  --strip-line-numbers Eliminar numeracion de lineas copiada desde chats/IA"
                echo "  --join-lines SPEC    Unir rangos: all, u3,7;9,14 o 3,7;9,14"
                echo "  --stdout             Imprimir resultado final sin tocar portapapeles/editor"
                echo "  --trim               Quitar bordes vacios y espacios finales"
                echo "  --dedent             Quitar indentacion comun"
                echo "  --strip-code-fence   Quitar fences Markdown de codigo"
                echo "  --strip-prompts      Quitar prompts de terminal copiados"
                echo "  --strip-wa-msgs      Quitar encabezados de mensajes copiados/exportados de WhatsApp"
                echo "  --wa-keep CAMPOS     Preservar metadata WA: name,date,time,datetime,all"
                echo "  --wa-place LUGAR     Ubicar metadata WA preservada: prefix o suffix"
                echo "  --squeeze-blank-lines Colapsar lineas vacias repetidas"
                echo "  --slug               Convertir texto a slug"
                echo "  --filename-safe      Convertir texto a nombre de archivo seguro"
                echo "  --wrap-code-fence LANG Envolver en fence Markdown"
                echo "  --dry-run            Mostrar plan y resultado sin tocar portapapeles/editor"
                echo "  --grep PATTERN       Conservar solo lineas que matchean regex"
                echo "  --grep-v PATTERN     Eliminar lineas que matchean regex"
                echo "  --version            Mostrar version"
                echo "  -h, --help           Mostrar esta ayuda"
                echo ""
                echo "Ejemplos:"
                echo "  clipedit                          # Abrir en editor (detectar formato)"
                echo "  clipedit -t markdown              # Convertir a Markdown"
                echo "  clipedit -f html -t markdown      # Forzar HTML a Markdown"
                echo "  clipedit -t html -s               # Convertir a HTML con source"
                echo "  clipedit -e vim                   # Abrir con Vim"
                echo "  clipedit -o ~/doc.md             # Guardar en archivo"
                echo "  clipedit --targets                # Ver formatos disponibles"
                echo "  clipedit --peek                   # Diagnosticar contenido actual"
                echo "  clipedit --target text/html       # Extraer HTML crudo"
                echo "  clipedit --plain                  # Texto plano directo al portapapeles"
                echo "  clipedit --strip-line-numbers --plain"
                echo "  clipedit --join-lines u3,7;9,14 --plain"
                echo "  clipedit --strip-code-fence --dedent --stdout"
                echo "  clipedit --wrap-code-fence bash --plain"
                echo "  clipedit --grep ERROR --stdout"
                echo "  clipedit --grep-v DEBUG --dry-run"
                echo "  clipedit --strip-wa-msgs --plain"
                echo "  clipedit --strip-wa-msgs --wa-keep name,date --wa-place suffix --stdout"
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ "$show_version" == "true" ]]; then
        echo "clipedit $VERSION"
        echo "repo: https://github.com/estudiochapunov/clipedit"
        return 0
    fi

    wa_keep=$(printf '%s' "$wa_keep" | tr -d '[:space:]')

    if [[ "$wa_place" != "prefix" && "$wa_place" != "suffix" ]]; then
        echo "Error: --wa-place acepta solo prefix o suffix" >&2
        return 1
    fi

    if [[ -n "$wa_keep" && ! "$wa_keep" =~ ^(name|date|time|datetime|all)(,(name|date|time|datetime|all))*$ ]]; then
        echo "Error: --wa-keep acepta name,date,time,datetime,all o listas separadas por coma" >&2
        return 1
    fi

    local icon_image="📷 "
    local icon_doc="📄 "
    local icon_warn="⚠️ "
    local icon_edit="📝 "
    local icon_clip="📋 "
    local icon_ok="✅ "
    if [[ "$no_emoji" == "true" ]]; then
        icon_image=""
        icon_doc=""
        icon_warn=""
        icon_edit=""
        icon_clip=""
        icon_ok=""
    fi
    
    # Obtener targets del portapapeles
    local targets
    targets=$(get_targets)

    if [[ -n "$raw_target" ]]; then
        if [[ -n "$output_file" ]]; then
            xclip -selection clipboard -t "$raw_target" -o > "$output_file"
            echo "${icon_doc}Guardado: $output_file"
        else
            xclip -selection clipboard -t "$raw_target" -o
        fi
        return 0
    fi
    
    # Detectar tipo de contenido si from=auto
    if [[ "$from" == "auto" ]]; then
        from=$(detect_content_type "$targets")
    fi

    if [[ "$show_targets" == "true" ]]; then
        print_targets "$targets"
        return 0
    fi

    if [[ "$peek" == "true" ]]; then
        peek_clipboard "$targets" "$from"
        return 0
    fi

    if [[ "$dry_run" == "true" && "$to" == "edit" ]]; then
        to="text"
    fi

    if [[ "$stdout_output" == "true" && "$to" == "edit" ]]; then
        to="text"
    fi

    if [[ "$copy_only" == "true" && "$to" == "edit" ]]; then
        to="text"
    fi
    
    # Determinar archivo de salida
    if [[ -n "$output_file" ]]; then
        temp_file="$output_file"
    else
        case "$to" in
            markdown) temp_file=$(mktemp /tmp/clip-XXXXXX.md) ;;
            html)     temp_file=$(mktemp /tmp/clip-XXXXXX.html) ;;
            text)     temp_file=$(mktemp /tmp/clip-XXXXXX.txt) ;;
            pdf)      temp_file=$(mktemp /tmp/clip-XXXXXX.html) ;;
            *)        temp_file=$(mktemp /tmp/clip-XXXXXX.txt) ;;
        esac
    fi
    
    # Procesar según tipo de contenido
    local source_url=""
    if [[ "$include_source" == "true" ]]; then
        source_url=$(get_source_url "$targets")
    fi
    
    # Imagen: extraer y guardar
    if [[ "$from" == image-png || "$from" == image-jpeg || "$from" == image-gif ]]; then
        local img_ext
        img_ext=$(get_image_ext "$from")
        local img_file
        img_file=$(mktemp /tmp/clipimg-XXXXXX.${img_ext})
        
        # Extraer imagen
        xclip -selection clipboard -t "image/${img_ext}" -o > "$img_file" 2>/dev/null || \
        xclip -selection clipboard -o > "$img_file"
        
        echo "${icon_image}Imagen guardada: $img_file"
        
        # Crear referencia según formato de salida
        case "$to" in
            markdown)
                echo "![image]($img_file)" > "$temp_file"
                ;;
            html)
                echo "<img src=\"$img_file\" alt=\"image\">" > "$temp_file"
                ;;
            *)
                echo "Imagen: $img_file" > "$temp_file"
                ;;
        esac
        
        if [[ -n "$output_file" ]]; then
            echo "${icon_doc}$temp_file"
        else
            # Copiar al portapapeles
            cat "$temp_file" | xclip -selection clipboard -i
            if [[ "$save_temp" == "true" ]]; then
                echo "${icon_doc}Temporal: $temp_file"
            else
                rm -f "$temp_file"
            fi
        fi
        return 0
    fi
    
    # Texto/HTML/RTF: procesar con pandoc
    local content
    content=$(get_clipboard_content "$from")
    content=$(apply_text_filters "$content" "$strip_line_numbers" "$join_lines_spec" "$trim_text" "$dedent_text" "$strip_code_fence" "$strip_prompts" "$squeeze_blank_lines" "$make_slug" "$make_filename" "$wrap_code_fence_lang" "$grep_pattern" "$grep_v_pattern" "$strip_wa_msgs" "$wa_keep" "$wa_place")
    
    # Agregar source si corresponde
    if [[ -n "$source_url" ]]; then
        content="Source: $source_url
---
$content"
    fi
    
    # Convertir según formato de salida
    case "$to" in
        markdown)
            echo "$content" | pandoc -f html -t markdown > "$temp_file" 2>/dev/null || \
            echo "$content" | pandoc -f rtf -t markdown > "$temp_file" 2>/dev/null || \
            echo "$content" > "$temp_file"
            ;;
        html)
            echo "$content" | pandoc -f markdown -t html > "$temp_file" 2>/dev/null || \
            echo "$content" > "$temp_file"
            ;;
        text)
            case "$from" in
                html)
                    echo "$content" | pandoc -f html -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                rtf)
                    echo "$content" | pandoc -f rtf -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                markdown)
                    echo "$content" | pandoc -f markdown -t plain > "$temp_file" 2>/dev/null || \
                    echo "$content" > "$temp_file"
                    ;;
                *)
                    echo "$content" > "$temp_file"
                    ;;
            esac
            ;;
        pdf)
            echo "$content" | pandoc -f markdown -t html > "$temp_file"
            # Crear PDF si wkhtmltopdf está disponible
            if command -v wkhtmltopdf &>/dev/null; then
                local pdf_file="${temp_file%.html}.pdf"
                wkhtmltopdf "$temp_file" "$pdf_file" 2>/dev/null
                rm -f "$temp_file"
                temp_file="$pdf_file"
                echo "${icon_doc}PDF: $temp_file"
            else
                echo "${icon_warn}wkhtmltopdf no está instalado (sudo apt install wkhtmltopdf)"
                echo "${icon_doc}Guardado como HTML: $temp_file"
            fi
            ;;
        edit)
            # Modo editor: abrir con editor
            echo "$content" > "$temp_file"
            
            if [[ -z "$editor" ]]; then
                editor=$(get_default_editor)
            fi
            
            open_editor_for_clipboard_review "$editor" "$temp_file" "$icon_edit"
            
            # Si es archivo temporal, preguntar si copiar de vuelta
            if [[ -z "$output_file" ]]; then
                echo "${icon_clip}¿Copiar al clipboard el contenido guardado del archivo temporal? (s/n)"
                read -r resp
                if [[ "$resp" == "s" || "$resp" == "S" ]]; then
                    cat "$temp_file" | xclip -selection clipboard -i
                    echo "${icon_ok}Copiado al clipboard"
                fi
                if [[ "$save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file"
                else
                    rm -f "$temp_file"
                fi
            else
                echo "${icon_doc}Guardado: $temp_file"
            fi
            return 0
            ;;
    esac
    
    # Si hay output file o es modo conversión
    if [[ -n "$output_file" || "$to" != "edit" ]]; then
        # Siempre mostrar donde quedó el archivo temporal
        if [[ -z "$output_file" && "$stdout_output" != "true" && "$dry_run" != "true" && ( "$copy_only" != "true" || "$save_temp" == "true" ) ]]; then
            echo "${icon_doc}Temporal: $temp_file"
        fi
        
        if [[ "$dry_run" == "true" ]]; then
            echo "ClipEdit dry-run"
            echo "from=$from"
            echo "to=$to"
            echo "output=stdout"
            echo "clipboard_write=false"
            echo "editor=false"
            echo "filters:"
            [[ "$strip_line_numbers" == "true" ]] && echo "  - strip-line-numbers"
            [[ -n "$join_lines_spec" ]] && echo "  - join-lines:$join_lines_spec"
            [[ "$trim_text" == "true" ]] && echo "  - trim"
            [[ "$dedent_text" == "true" ]] && echo "  - dedent"
            [[ "$strip_code_fence" == "true" ]] && echo "  - strip-code-fence"
            [[ "$strip_prompts" == "true" ]] && echo "  - strip-prompts"
            [[ "$strip_wa_msgs" == "true" ]] && echo "  - strip-wa-msgs"
            [[ -n "$wa_keep" ]] && echo "  - wa-keep:$wa_keep"
            [[ "$strip_wa_msgs" == "true" && -n "$wa_keep" ]] && echo "  - wa-place:$wa_place"
            [[ "$squeeze_blank_lines" == "true" ]] && echo "  - squeeze-blank-lines"
            [[ "$make_slug" == "true" ]] && echo "  - slug"
            [[ "$make_filename" == "true" ]] && echo "  - filename-safe"
            [[ -n "$wrap_code_fence_lang" ]] && echo "  - wrap-code-fence:$wrap_code_fence_lang"
            [[ -n "$grep_pattern" ]] && echo "  - grep:$grep_pattern"
            [[ -n "$grep_v_pattern" ]] && echo "  - grep-v:$grep_v_pattern"
            echo "---"
            cat "$temp_file"
            if [[ -z "$output_file" ]]; then
                if [[ "$save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file" >&2
                else
                    rm -f "$temp_file"
                fi
            fi
            return 0
        fi

        if [[ "$stdout_output" == "true" ]]; then
            cat "$temp_file"
            if [[ -z "$output_file" ]]; then
                if [[ "$save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file" >&2
                else
                    rm -f "$temp_file"
                fi
            fi
            return 0
        fi

        if [[ "$copy_only" == "true" ]]; then
            cat "$temp_file" | xclip -selection clipboard -i
            echo "${icon_ok}Copiado al clipboard"
            if [[ -z "$output_file" ]]; then
                if [[ "$save_temp" == "true" ]]; then
                    echo "${icon_doc}Temporal conservado: $temp_file"
                else
                    rm -f "$temp_file"
                fi
            fi
            echo "${icon_ok}Convertido a $to"
            return 0
        fi

        # Abrir en editor para revisar resultado
        if [[ -z "$output_file" ]]; then
            local editor
            editor=$(get_default_editor)
            open_editor_for_clipboard_review "$editor" "$temp_file" "$icon_edit"
            
            # Preguntar si copiar al portapapeles
            echo "${icon_clip}¿Copiar al clipboard el contenido guardado del archivo temporal? (s/n)"
            read -r resp
            if [[ "$resp" == "s" || "$resp" == "S" ]]; then
                cat "$temp_file" | xclip -selection clipboard -i
                echo "${icon_ok}Copiado al clipboard"
            fi
            if [[ "$save_temp" == "true" ]]; then
                echo "${icon_doc}Temporal conservado: $temp_file"
            else
                rm -f "$temp_file"
            fi
        else
            cat "$temp_file" | xclip -selection clipboard -i
            echo "${icon_doc}Guardado: $temp_file"
        fi
    fi

    echo "${icon_ok}Convertido a $to"
}

main "$@"
